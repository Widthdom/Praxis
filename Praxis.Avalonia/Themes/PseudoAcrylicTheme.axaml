    <Setter Property="BorderBrush" Value="#66333333" />
    <Setter Property="BoxShadow" Value="0 12 28 0 #44000000, inset 0 1 0 0 #66FFFFFF" />
  </Style>

  <Style Selector="Window.light Border.praxis-copy-toast Path">
    <Setter Property="Stroke" Value="#333333" />
  </Style>

  <Style Selector="Border.praxis-resize-n">
    <Setter Property="Height" Value="4" />
    <Setter Property="Margin" Value="10,0,10,0" />
    <Setter Property="VerticalAlignment" Value="Top" />
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="Cursor" Value="SizeNorthSouth" />
  </Style>

  <Style Selector="Border.praxis-resize-s">
    <Setter Property="Height" Value="4" />
    <Setter Property="Margin" Value="10,0,10,0" />
    <Setter Property="VerticalAlignment" Value="Bottom" />
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="Cursor" Value="SizeNorthSouth" />
  </Style>

  <Style Selector="Border.praxis-resize-w">
    <Setter Property="Width" Value="4" />
    <Setter Property="Margin" Value="0,10,0,10" />
    <Setter Property="HorizontalAlignment" Value="Left" />
    <Setter Property="VerticalAlignment" Value="Stretch" />
    <Setter Property="Cursor" Value="SizeWestEast" />
  </Style>

  <Style Selector="Border.praxis-resize-e">
    <Setter Property="Width" Value="4" />
