<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Styles.Resources>
    <LinearGradientBrush x:Key="PraxisShellBackground" StartPoint="0%,0%" EndPoint="100%,100%">
      <GradientStop Color="#F0202020" Offset="0" />
      <GradientStop Color="#E2323232" Offset="0.42" />
      <GradientStop Color="#DC191919" Offset="0.72" />
      <GradientStop Color="#EE262626" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="PraxisLightShellBackground" StartPoint="0%,0%" EndPoint="100%,100%">
      <GradientStop Color="#B8FFFFFF" Offset="0" />
      <GradientStop Color="#9ADCDCDC" Offset="0.5" />
      <GradientStop Color="#E0FFFFFF" Offset="1" />
    </LinearGradientBrush>
    <SolidColorBrush x:Key="PraxisSurfaceBrush" Color="#2E2E2E" Opacity="0.78" />
    <SolidColorBrush x:Key="PraxisSurfaceStrongBrush" Color="#3A3A3A" Opacity="0.9" />
    <SolidColorBrush x:Key="PraxisTextPrimaryBrush" Color="#F4F4F4" />
    <SolidColorBrush x:Key="PraxisTextSecondaryBrush" Color="#B0B0B0" />
    <SolidColorBrush x:Key="PraxisPlaceholderBrush" Color="#8E8E8E" />
    <SolidColorBrush x:Key="PraxisAccentBrush" Color="#A0A0A0" />
    <LinearGradientBrush x:Key="PraxisGlassBackdropBrush" StartPoint="0%,0%" EndPoint="100%,100%">
      <GradientStop Color="#B81A1A1A" Offset="0" />
      <GradientStop Color="#C0383838" Offset="0.48" />
      <GradientStop Color="#B4141414" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="PraxisLightGlassBackdropBrush" StartPoint="0%,0%" EndPoint="100%,100%">
      <GradientStop Color="#B8FFFFFF" Offset="0" />
      <GradientStop Color="#AAD0D0D0" Offset="0.5" />
      <GradientStop Color="#C8FFFFFF" Offset="1" />
    </LinearGradientBrush>
  </Styles.Resources>

  <Style Selector="Window.praxis-main">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="FontFamily" Value="Inter, Hiragino Sans, Yu Gothic, Meiryo, Segoe UI, -apple-system, BlinkMacSystemFont" />
    <Setter Property="Foreground" Value="{StaticResource PraxisTextPrimaryBrush}" />
  </Style>

  <Style Selector="Window.praxis-main.light">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground" Value="#1A1A1A" />
  </Style>

  <Style Selector="Window.praxis-main.fullscreen">
    <Setter Property="Background" Value="Transparent" />
  </Style>

  <Style Selector="Window.praxis-main.light.fullscreen">
    <Setter Property="Background" Value="Transparent" />
  </Style>

  <Style Selector="Border.praxis-shell">
    <Setter Property="Background" Value="{StaticResource PraxisShellBackground}" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="ClipToBounds" Value="True" />
    <Setter Property="BorderBrush" Value="#30FFFFFF" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="BoxShadow" Value="inset 0 1 0 0 #28FFFFFF" />
  </Style>

  <Style Selector="Border.praxis-acrylic-sheen">
    <Setter Property="Background">
      <Setter.Value>
        <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
          <GradientStop Color="#34FFFFFF" Offset="0" />
          <GradientStop Color="#12000000" Offset="0.24" />
          <GradientStop Color="#28FFFFFF" Offset="0.48" />
          <GradientStop Color="#12000000" Offset="0.72" />
          <GradientStop Color="#20FFFFFF" Offset="1" />
        </LinearGradientBrush>
      </Setter.Value>
    </Setter>
  </Style>

  <Style Selector="Window.light Border.praxis-acrylic-sheen">
    <Setter Property="Background">
      <Setter.Value>
        <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
          <GradientStop Color="#DCFFFFFF" Offset="0" />
          <GradientStop Color="#66B8B8B8" Offset="0.26" />
          <GradientStop Color="#88FFFFFF" Offset="0.5" />
          <GradientStop Color="#78BEBEBE" Offset="0.72" />
          <GradientStop Color="#B0FFFFFF" Offset="1" />
        </LinearGradientBrush>
      </Setter.Value>
    </Setter>
  </Style>

  <Style Selector="Window.praxis-main Border.praxis-shell">
    <Setter Property="CornerRadius" Value="8" />
  </Style>

  <Style Selector="Window.fullscreen Border.praxis-shell">
    <Setter Property="CornerRadius" Value="0" />
  </Style>

  <Style Selector="Window.light Border.praxis-shell">
    <Setter Property="Background" Value="{StaticResource PraxisLightShellBackground}" />
    <Setter Property="BorderBrush" Value="#80FFFFFF" />
    <Setter Property="BoxShadow" Value="inset 0 1 0 0 #CCFFFFFF" />
  </Style>

  <Style Selector="TextBox.praxis-input">
    <Setter Property="Background" Value="#565656" />
    <Setter Property="Foreground" Value="{StaticResource PraxisTextPrimaryBrush}" />
    <Setter Property="BorderThickness" Value="2" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="CornerRadius" Value="4" />
    <Setter Property="Padding" Value="14,0" />
    <Setter Property="Height" Value="42" />
    <Setter Property="MinHeight" Value="42" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
    <Setter Property="CaretBrush" Value="{StaticResource PraxisTextPrimaryBrush}" />
    <Setter Property="SelectionBrush" Value="#55777777" />
    <Setter Property="FocusAdorner" Value="{x:Null}" />
  </Style>

  <Style Selector="TextBox.praxis-input:focus">
    <Setter Property="Background" Value="#565656" />
    <Setter Property="BorderThickness" Value="2" />
    <Setter Property="BorderBrush" Value="#A0A0A0" />
    <Setter Property="Padding" Value="14,0" />
  </Style>

  <Style Selector="TextBox.praxis-input /template/ Border#PART_BorderElement">
    <Setter Property="Background" Value="#565656" />
    <Setter Property="BorderThickness" Value="2" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="CornerRadius" Value="4" />
  </Style>

  <Style Selector="TextBox.praxis-input:focus /template/ Border#PART_BorderElement">
    <Setter Property="Background" Value="#565656" />
    <Setter Property="BorderThickness" Value="2" />
    <Setter Property="BorderBrush" Value="#A0A0A0" />
  </Style>

  <Style Selector="TextBox.praxis-input:pointerover">
    <Setter Property="Background" Value="#565656" />
  </Style>

  <Style Selector="TextBox.praxis-input:pointerover /template/ Border#PART_BorderElement">
    <Setter Property="Background" Value="#565656" />
  </Style>

  <Style Selector="Window.light TextBox.praxis-input">
    <Setter Property="Background" Value="#F2F2F2" />
    <Setter Property="Foreground" Value="#111111" />
    <Setter Property="CaretBrush" Value="#111111" />
    <Setter Property="SelectionBrush" Value="#55999999" />
  </Style>

  <Style Selector="Window.light TextBox.praxis-input:focus">
    <Setter Property="Background" Value="#F2F2F2" />
  </Style>

  <Style Selector="Window.light TextBox.praxis-input /template/ Border#PART_BorderElement">
    <Setter Property="Background" Value="#F2F2F2" />
  </Style>

  <Style Selector="Window.light TextBox.praxis-input:focus /template/ Border#PART_BorderElement">
    <Setter Property="Background" Value="#F2F2F2" />
  </Style>

  <Style Selector="Window.light TextBox.praxis-input:pointerover">
    <Setter Property="Background" Value="#F2F2F2" />
  </Style>

  <Style Selector="Window.light TextBox.praxis-input:pointerover /template/ Border#PART_BorderElement">
    <Setter Property="Background" Value="#F2F2F2" />
  </Style>

  <Style Selector="Grid.praxis-placeholder-icon">
    <Setter Property="Width" Value="18" />
    <Setter Property="Height" Value="18" />
    <Setter Property="Margin" Value="13,0,0,0" />
    <Setter Property="HorizontalAlignment" Value="Left" />
    <Setter Property="VerticalAlignment" Value="Center" />
    <Setter Property="IsHitTestVisible" Value="False" />
  </Style>

  <Style Selector="Canvas.praxis-search-icon">
    <Setter Property="Margin" Value="13,0,0,0" />
    <Setter Property="HorizontalAlignment" Value="Left" />
  </Style>

  <Style Selector="Button.praxis-create">
    <Setter Property="Background" Value="#565656" />
    <Setter Property="Foreground" Value="{StaticResource PraxisTextPrimaryBrush}" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="CornerRadius" Value="4" />
    <Setter Property="Padding" Value="8,5" />
    <Setter Property="Height" Value="40" />
    <Setter Property="MinHeight" Value="40" />
    <Setter Property="Template">
      <ControlTemplate>
        <Border Background="{TemplateBinding Background}"
                BorderBrush="{TemplateBinding BorderBrush}"
                BorderThickness="{TemplateBinding BorderThickness}"
                CornerRadius="{TemplateBinding CornerRadius}">
          <ContentPresenter Content="{TemplateBinding Content}"
                            ContentTemplate="{TemplateBinding ContentTemplate}"
                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                            Margin="{TemplateBinding Padding}" />
        </Border>
      </ControlTemplate>
    </Setter>
  </Style>

  <Style Selector="Button.praxis-create:pointerover">
    <Setter Property="Background" Value="#444444" />
  </Style>

  <Style Selector="Window.light Button.praxis-create">
    <Setter Property="Background" Value="#F2F2F2" />
    <Setter Property="Foreground" Value="#777777" />
  </Style>

  <Style Selector="Window.light Button.praxis-create:pointerover">
    <Setter Property="Background" Value="#D0D0D0" />
    <Setter Property="Foreground" Value="#666666" />
  </Style>

  <Style Selector="Button.praxis-traffic">
    <Setter Property="Width" Value="13" />
    <Setter Property="Height" Value="13" />
    <Setter Property="MinWidth" Value="13" />
    <Setter Property="MinHeight" Value="13" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="CornerRadius" Value="7" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="RenderTransformOrigin" Value="50%,50%" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
    <Setter Property="Template">
      <ControlTemplate>
        <Border Background="{TemplateBinding Background}"
                CornerRadius="{TemplateBinding CornerRadius}">
          <ContentPresenter Content="{TemplateBinding Content}"
                            ContentTemplate="{TemplateBinding ContentTemplate}"
                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
        </Border>
      </ControlTemplate>
    </Setter>
  </Style>

  <Style Selector="Button.praxis-traffic:pointerover">
    <Setter Property="Opacity" Value="1" />
  </Style>

  <Style Selector="Button.praxis-close:pointerover">
    <Setter Property="Background" Value="#D8D8D8" />
  </Style>

  <Style Selector="Button.praxis-minimize:pointerover">
    <Setter Property="Background" Value="#B8B8B8" />
  </Style>

  <Style Selector="Button.praxis-maximize:pointerover">
    <Setter Property="Background" Value="#989898" />
  </Style>

  <Style Selector="Button.praxis-traffic:focus /template/ ContentPresenter">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
  </Style>

  <Style Selector="Button.praxis-traffic:pressed">
    <Setter Property="RenderTransform" Value="none" />
  </Style>

  <Style Selector="Grid.praxis-traffic-symbol">
    <Setter Property="Opacity" Value="0" />
    <Setter Property="Width" Value="13" />
    <Setter Property="Height" Value="13" />
    <Setter Property="HorizontalAlignment" Value="Center" />
    <Setter Property="VerticalAlignment" Value="Center" />
    <Setter Property="IsHitTestVisible" Value="False" />
  </Style>

  <Style Selector="Grid.praxis-traffic-symbol Path">
    <Setter Property="Stretch" Value="None" />
  </Style>

  <Style Selector="Grid.praxis-traffic-close-glyph Path">
    <Setter Property="Stroke" Value="#4A4A4A" />
  </Style>

  <Style Selector="Grid.praxis-traffic-minimize-glyph Path">
    <Setter Property="Stroke" Value="#4A4A4A" />
  </Style>

  <Style Selector="Grid.praxis-traffic-fullscreen-glyph Path">
    <Setter Property="Fill" Value="#3A3A3A" />
    <Setter Property="Stroke" Value="Transparent" />
  </Style>

  <Style Selector="StackPanel:pointerover Grid.praxis-traffic-symbol">
    <Setter Property="Opacity" Value="1" />
  </Style>

  <Style Selector="Button.praxis-close">
    <Setter Property="Background" Value="#D8D8D8" />
  </Style>

  <Style Selector="Button.praxis-minimize">
    <Setter Property="Background" Value="#B8B8B8" />
  </Style>

  <Style Selector="Button.praxis-minimize:disabled">
    <Setter Property="Background" Value="#7A7A7A" />
    <Setter Property="Opacity" Value="0.58" />
  </Style>

  <Style Selector="Button.praxis-minimize:disabled TextBlock.praxis-traffic-glyph">
    <Setter Property="Foreground" Value="#555555" />
  </Style>

  <Style Selector="Button.praxis-minimize:disabled Grid.praxis-traffic-minimize-glyph Path">
    <Setter Property="Stroke" Value="#555555" />
  </Style>

  <Style Selector="Button.praxis-maximize">
    <Setter Property="Background" Value="#989898" />
  </Style>

  <Style Selector="Button.praxis-caption">
    <Setter Property="Width" Value="36" />
    <Setter Property="Height" Value="28" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground" Value="{StaticResource PraxisTextPrimaryBrush}" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="CornerRadius" Value="4" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
  </Style>

  <Style Selector="Button.praxis-caption:pointerover">
    <Setter Property="Background" Value="#363636" />
  </Style>

  <Style Selector="Border.praxis-suggestion-panel">
    <Setter Property="Background" Value="#262626" />
    <Setter Property="BorderBrush" Value="#444444" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="4" />
    <Setter Property="Padding" Value="4" />
  </Style>

  <Style Selector="Window.light Border.praxis-suggestion-panel">
    <Setter Property="Background" Value="#F5F5F5" />
    <Setter Property="BorderBrush" Value="#D0D0D0" />
  </Style>

  <Style Selector="Button.praxis-suggestion">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground" Value="{StaticResource PraxisTextPrimaryBrush}" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="CornerRadius" Value="3" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    <Setter Property="MinHeight" Value="38" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
  </Style>

  <Style Selector="Window.light Button.praxis-suggestion">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground" Value="#111111" />
  </Style>

  <Style Selector="Button.praxis-suggestion:pointerover">
    <Setter Property="Background" Value="#555555" />
  </Style>

  <Style Selector="Window.light Button.praxis-suggestion:pointerover">
    <Setter Property="Background" Value="#CFCFCF" />
  </Style>

  <Style Selector="Border.praxis-placement-frame">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="CornerRadius" Value="0" />
    <Setter Property="ClipToBounds" Value="True" />
  </Style>

  <Style Selector="Button.praxis-launcher">
    <Setter Property="Foreground" Value="{StaticResource PraxisTextPrimaryBrush}" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="CornerRadius" Value="4" />
    <Setter Property="Padding" Value="12,8" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
    <Setter Property="Template">
      <ControlTemplate>
        <Border Background="{TemplateBinding Background}"
                BorderBrush="{TemplateBinding BorderBrush}"
                BorderThickness="{TemplateBinding BorderThickness}"
                CornerRadius="{TemplateBinding CornerRadius}">
          <ContentPresenter Content="{TemplateBinding Content}"
                            ContentTemplate="{TemplateBinding ContentTemplate}"
                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                            Margin="{TemplateBinding Padding}" />
        </Border>
      </ControlTemplate>
    </Setter>
  </Style>

  <Style Selector="Button.praxis-launcher:pointerover">
    <Setter Property="Opacity" Value="1" />
  </Style>

  <Style Selector="Border.praxis-selection-rect">
    <Setter Property="Background" Value="#33777777" />
    <Setter Property="BorderBrush" Value="#B0B0B0" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="2" />
  </Style>

  <Style Selector="Border.praxis-status-bar">
    <Setter Property="CornerRadius" Value="4" />
    <Setter Property="ClipToBounds" Value="True" />
  </Style>

  <Style Selector="Button.praxis-dock">
    <Setter Property="Foreground" Value="{StaticResource PraxisTextPrimaryBrush}" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="CornerRadius" Value="4" />
    <Setter Property="Padding" Value="12,8" />
    <Setter Property="MinHeight" Value="40" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
    <Setter Property="Template">
      <ControlTemplate>
        <Border Background="{TemplateBinding Background}"
                BorderBrush="{TemplateBinding BorderBrush}"
                BorderThickness="{TemplateBinding BorderThickness}"
                CornerRadius="{TemplateBinding CornerRadius}">
          <ContentPresenter Content="{TemplateBinding Content}"
                            ContentTemplate="{TemplateBinding ContentTemplate}"
                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                            Margin="{TemplateBinding Padding}" />
        </Border>
      </ControlTemplate>
    </Setter>
  </Style>

  <Style Selector="Button.praxis-dock:pointerover">
    <Setter Property="Opacity" Value="1" />
  </Style>

  <Style Selector="ScrollViewer.praxis-dock-scroll">
    <Setter Property="MinHeight" Value="70" />
  </Style>

  <Style Selector="Border.praxis-context-menu">
    <Setter Property="Background" Value="#262626" />
    <Setter Property="BorderBrush" Value="#505050" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="5" />
    <Setter Property="Padding" Value="8" />
  </Style>

  <Style Selector="Window.light Border.praxis-context-menu">
    <Setter Property="Background" Value="#F5F5F5" />
    <Setter Property="BorderBrush" Value="#C6C6C6" />
  </Style>

  <Style Selector="Grid.praxis-glass-backdrop">
    <Setter Property="Background" Value="{StaticResource PraxisGlassBackdropBrush}" />
  </Style>

  <Style Selector="Window.light Grid.praxis-glass-backdrop">
    <Setter Property="Background" Value="{StaticResource PraxisLightGlassBackdropBrush}" />
  </Style>

  <Style Selector="Button.praxis-menu-button">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground" Value="{StaticResource PraxisTextPrimaryBrush}" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="CornerRadius" Value="4" />
    <Setter Property="MinWidth" Value="128" />
    <Setter Property="Padding" Value="12,7" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="FocusAdorner" Value="{x:Null}" />
    <Setter Property="Template">
      <ControlTemplate>
        <Border Background="{TemplateBinding Background}"
                BorderBrush="{TemplateBinding BorderBrush}"
                BorderThickness="{TemplateBinding BorderThickness}"
                CornerRadius="{TemplateBinding CornerRadius}">
          <ContentPresenter Content="{TemplateBinding Content}"
                            ContentTemplate="{TemplateBinding ContentTemplate}"
                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                            Margin="{TemplateBinding Padding}" />
        </Border>
      </ControlTemplate>
    </Setter>
  </Style>

  <Style Selector="Button.praxis-menu-button:pointerover">
    <Setter Property="Background" Value="Transparent" />
  </Style>

  <Style Selector="Button.praxis-menu-button:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="Transparent" />
  </Style>

  <Style Selector="Button.praxis-menu-button:focus">
    <Setter Property="Background" Value="{StaticResource PraxisSurfaceStrongBrush}" />
    <Setter Property="BorderThickness" Value="0" />
  </Style>

  <Style Selector="Button.praxis-menu-button:focus:pointerover">
    <Setter Property="Background" Value="{StaticResource PraxisSurfaceStrongBrush}" />
  </Style>

  <Style Selector="Button.praxis-menu-button:focus:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="{StaticResource PraxisSurfaceStrongBrush}" />
  </Style>

  <Style Selector="Button.praxis-menu-button:pressed">
    <Setter Property="Background" Value="Transparent" />
  </Style>

  <Style Selector="Button.praxis-menu-button:focus:pressed">
    <Setter Property="Background" Value="{StaticResource PraxisSurfaceStrongBrush}" />
  </Style>

  <Style Selector="Window.light Button.praxis-menu-button">
    <Setter Property="Foreground" Value="#1A1A1A" />
  </Style>

  <Style Selector="Window.light Button.praxis-menu-button:pointerover">
    <Setter Property="Background" Value="Transparent" />
  </Style>

  <Style Selector="Window.light Button.praxis-menu-button:focus">
    <Setter Property="Background" Value="#DADADA" />
  </Style>

  <Style Selector="Window.light Button.praxis-menu-button:focus:pointerover">
    <Setter Property="Background" Value="#DADADA" />
  </Style>

  <Style Selector="Window.light Button.praxis-menu-button:focus:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="#DADADA" />
  </Style>

  <Style Selector="Window.light Button.praxis-menu-button:pressed">
    <Setter Property="Background" Value="Transparent" />
  </Style>

  <Style Selector="Window.light Button.praxis-menu-button:focus:pressed">
    <Setter Property="Background" Value="#DADADA" />
  </Style>

  <Style Selector="Border.praxis-editor-modal">
    <Setter Property="Background" Value="#262626" />
    <Setter Property="BorderBrush" Value="#505050" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="6" />
    <Setter Property="Padding" Value="16" />
  </Style>

  <Style Selector="Window.light Border.praxis-editor-modal">
    <Setter Property="Background" Value="#F8F8F8" />
    <Setter Property="BorderBrush" Value="#C6C6C6" />
  </Style>

  <Style Selector="TextBlock.praxis-editor-label">
    <Setter Property="Foreground" Value="{StaticResource PraxisTextSecondaryBrush}" />
    <Setter Property="FontSize" Value="12" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Height" Value="38" />
    <Setter Property="LineHeight" Value="38" />
    <Setter Property="VerticalAlignment" Value="Center" />
    <Setter Property="TextAlignment" Value="Left" />
  </Style>

  <Style Selector="Grid.praxis-editor-field TextBox.praxis-input">
    <Setter Property="Background" Value="#646464" />
    <Setter Property="Padding" Value="12,0" />
    <Setter Property="Height" Value="38" />
    <Setter Property="MinHeight" Value="38" />
  </Style>

  <Style Selector="Grid.praxis-editor-field TextBox.praxis-input /template/ Border#PART_BorderElement">
    <Setter Property="Background" Value="#646464" />
  </Style>

  <Style Selector="Grid.praxis-editor-field TextBox.praxis-input:focus">
    <Setter Property="Background" Value="#646464" />
    <Setter Property="Padding" Value="12,0" />
    <Setter Property="BorderThickness" Value="2" />
  </Style>

  <Style Selector="Grid.praxis-editor-field TextBox.praxis-input:focus /template/ Border#PART_BorderElement">
    <Setter Property="Background" Value="#646464" />
  </Style>

  <Style Selector="Window.light Grid.praxis-editor-field TextBox.praxis-input">
    <Setter Property="Background" Value="#E6E6E6" />
  </Style>

  <Style Selector="Window.light Grid.praxis-editor-field TextBox.praxis-input /template/ Border#PART_BorderElement">
    <Setter Property="Background" Value="#E6E6E6" />
  </Style>

  <Style Selector="Window.light Grid.praxis-editor-field TextBox.praxis-input:focus">
    <Setter Property="Background" Value="#E6E6E6" />
  </Style>

  <Style Selector="Window.light Grid.praxis-editor-field TextBox.praxis-input:focus /template/ Border#PART_BorderElement">
    <Setter Property="Background" Value="#E6E6E6" />
  </Style>

  <Style Selector="Button.praxis-copy-button">
    <Setter Property="Opacity" Value="0.001" />
    <Setter Property="Width" Value="30" />
    <Setter Property="Height" Value="38" />
    <Setter Property="HorizontalAlignment" Value="Right" />
    <Setter Property="VerticalAlignment" Value="Center" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="Foreground" Value="#B8B8B8" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="CornerRadius" Value="4" />
    <Setter Property="FontSize" Value="16" />
    <Setter Property="IsTabStop" Value="False" />
    <Setter Property="FocusAdorner" Value="{x:Null}" />
  </Style>

  <Style Selector="Button.praxis-copy-button:pointerover">
    <Setter Property="Opacity" Value="0.82" />
    <Setter Property="Background" Value="Transparent" />
  </Style>

  <Style Selector="Window.light Button.praxis-copy-button">
    <Setter Property="Foreground" Value="#666666" />
  </Style>

  <Style Selector="Button.praxis-copy-button:pointerover /template/ ContentPresenter">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
  </Style>

  <Style Selector="Button.praxis-copy-button:pointerover /template/ Border">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
  </Style>

  <Style Selector="Button.praxis-copy-button:pressed">
    <Setter Property="Background" Value="Transparent" />
  </Style>

  <Style Selector="Button.praxis-copy-button:pressed /template/ ContentPresenter">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
  </Style>

  <Style Selector="Button.praxis-copy-button:pressed /template/ Border">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
  </Style>

  <Style Selector="Button.praxis-copy-button Path">
    <Setter Property="Width" Value="15" />
    <Setter Property="Height" Value="15" />
    <Setter Property="Stretch" Value="Uniform" />
    <Setter Property="HorizontalAlignment" Value="Center" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <Style Selector="Button.praxis-clear-button">
    <Setter Property="Width" Value="22" />
    <Setter Property="Height" Value="22" />
    <Setter Property="HorizontalAlignment" Value="Right" />
    <Setter Property="VerticalAlignment" Value="Center" />
    <Setter Property="Margin" Value="0,0,9,0" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="Background" Value="#777777" />
    <Setter Property="Foreground" Value="{StaticResource PraxisTextPrimaryBrush}" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="CornerRadius" Value="11" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
  </Style>

  <Style Selector="Button.praxis-clear-button Path">
    <Setter Property="Width" Value="8" />
    <Setter Property="Height" Value="8" />
    <Setter Property="HorizontalAlignment" Value="Center" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <Style Selector="Button.praxis-clear-button:pointerover">
    <Setter Property="Background" Value="#777777" />
  </Style>

  <Style Selector="Window.light Button.praxis-clear-button">
    <Setter Property="Background" Value="#D0D0D0" />
    <Setter Property="Foreground" Value="#555555" />
  </Style>

  <Style Selector="Window.light Button.praxis-clear-button:pointerover">
    <Setter Property="Background" Value="#D0D0D0" />
  </Style>

  <Style Selector="Window.light Button.praxis-clear-button Path">
    <Setter Property="Stroke" Value="#555555" />
  </Style>

  <Style Selector="CheckBox.praxis-invert-check">
    <Setter Property="Foreground" Value="{StaticResource PraxisTextPrimaryBrush}" />
    <Setter Property="Background" Value="#646464" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="FocusAdorner" Value="{x:Null}" />
    <Setter Property="Template">
      <ControlTemplate>
        <StackPanel Orientation="Horizontal"
                    Spacing="8">
          <Border Width="18"
                  Height="18"
                  CornerRadius="3"
                  BorderThickness="0"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  Background="{TemplateBinding Background}"
                  VerticalAlignment="Center">
            <Path Classes="praxis-check-glyph"
                  Data="M 4 9 L 7.2 12 L 14 5"
                  Stroke="{TemplateBinding Foreground}"
                  StrokeThickness="2"
                  StrokeLineCap="Round"
                  StrokeJoin="Round"
                  Opacity="0" />
          </Border>
          <ContentPresenter Content="{TemplateBinding Content}"
                            ContentTemplate="{TemplateBinding ContentTemplate}"
                            VerticalAlignment="Center" />
        </StackPanel>
      </ControlTemplate>
    </Setter>
  </Style>

  <Style Selector="CheckBox.praxis-invert-check:checked Path.praxis-check-glyph">
    <Setter Property="Opacity" Value="1" />
  </Style>

  <Style Selector="Window.light CheckBox.praxis-invert-check">
    <Setter Property="Foreground" Value="#1A1A1A" />
    <Setter Property="Background" Value="#E6E6E6" />
    <Setter Property="BorderBrush" Value="Transparent" />
  </Style>

  <Style Selector="Grid.praxis-tooltip-grid">
    <Setter Property="RowSpacing" Value="1" />
    <Setter Property="ColumnSpacing" Value="10" />
    <Setter Property="MaxWidth" Value="540" />
  </Style>

  <Style Selector="Grid.praxis-tooltip-grid TextBlock">
    <Setter Property="FontFamily" Value="Inter, Hiragino Sans, Yu Gothic, Meiryo, Segoe UI, -apple-system, BlinkMacSystemFont" />
  </Style>

  <Style Selector="ToolTip">
    <Setter Property="FontFamily" Value="Inter, Hiragino Sans, Yu Gothic, Meiryo, Segoe UI, -apple-system, BlinkMacSystemFont" />
  </Style>

  <Style Selector="TextBlock.praxis-tooltip-label">
    <Setter Property="FontWeight" Value="Bold" />
  </Style>

  <Style Selector="MenuFlyoutPresenter">
    <Setter Property="Background" Value="#262626" />
    <Setter Property="BorderBrush" Value="#505050" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="6" />
    <Setter Property="Padding" Value="8" />
  </Style>

  <Style Selector="Window.light MenuFlyoutPresenter">
    <Setter Property="Background" Value="#F5F5F5" />
    <Setter Property="BorderBrush" Value="#C6C6C6" />
  </Style>

  <Style Selector="MenuItem">
    <Setter Property="MinHeight" Value="28" />
    <Setter Property="Padding" Value="12,5" />
    <Setter Property="Margin" Value="2" />
    <Setter Property="CornerRadius" Value="4" />
  </Style>

  <Style Selector="Border.praxis-resize-edge">
    <Setter Property="Background" Value="#01000000" />
    <Setter Property="ZIndex" Value="2000" />
  </Style>

  <Style Selector="Border.praxis-resize-corner">
    <Setter Property="Background" Value="#01000000" />
    <Setter Property="ZIndex" Value="2100" />
    <Setter Property="Width" Value="6" />
    <Setter Property="Height" Value="6" />
  </Style>

  <Style Selector="Border.praxis-copy-toast">
    <Setter Property="Width" Value="54" />
    <Setter Property="Height" Value="42" />
    <Setter Property="Background" Value="#D82F2F2F" />
    <Setter Property="BorderBrush" Value="#40FFFFFF" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="8" />
    <Setter Property="Padding" Value="12" />
    <Setter Property="BoxShadow" Value="0 12 28 0 #66000000, inset 0 1 0 0 #26FFFFFF" />
  </Style>

  <Style Selector="Border.praxis-copy-toast Path">
    <Setter Property="Stroke" Value="{StaticResource PraxisTextPrimaryBrush}" />
    <Setter Property="Stretch" Value="Uniform" />
    <Setter Property="Width" Value="18" />
    <Setter Property="Height" Value="18" />
    <Setter Property="HorizontalAlignment" Value="Center" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <Style Selector="Window.light Border.praxis-copy-toast">
