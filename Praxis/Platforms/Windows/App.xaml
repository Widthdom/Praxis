<maui:MauiWinUIApplication
    x:Class="Praxis.WinUI.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:maui="using:Microsoft.Maui"
    xmlns:local="using:Praxis.WinUI">
    <maui:MauiWinUIApplication.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Default">
                    <Color x:Key="TextOnAccentFillColorSelectedText">#FFF5F7FA</Color>
                    <SolidColorBrush x:Key="TextOnAccentFillColorSelectedTextBrush" Color="{StaticResource TextOnAccentFillColorSelectedText}" />
                    <SolidColorBrush x:Key="TextControlSelectionHighlightForeground" Color="{StaticResource TextOnAccentFillColorSelectedText}" />
                    <SolidColorBrush x:Key="TextControlSelectionHighlightColor" Color="#FF6B4BB0" />
                    <SolidColorBrush x:Key="TextSelectionHighlightColorThemeBrush" Color="#FF6B4BB0" />
                    <SolidColorBrush x:Key="AccentFillColorSelectedTextBackgroundBrush" Color="#FF6B4BB0" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Light">
                    <Color x:Key="TextOnAccentFillColorSelectedText">#FFF5F7FA</Color>
                    <SolidColorBrush x:Key="TextOnAccentFillColorSelectedTextBrush" Color="{StaticResource TextOnAccentFillColorSelectedText}" />
                    <SolidColorBrush x:Key="TextControlSelectionHighlightForeground" Color="{StaticResource TextOnAccentFillColorSelectedText}" />
                    <SolidColorBrush x:Key="TextControlSelectionHighlightColor" Color="#FF6B4BB0" />
                    <SolidColorBrush x:Key="TextSelectionHighlightColorThemeBrush" Color="#FF6B4BB0" />
                    <SolidColorBrush x:Key="AccentFillColorSelectedTextBackgroundBrush" Color="#FF6B4BB0" />
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <Color x:Key="TextOnAccentFillColorSelectedText">#FFF5F7FA</Color>
                    <SolidColorBrush x:Key="TextOnAccentFillColorSelectedTextBrush" Color="{StaticResource TextOnAccentFillColorSelectedText}" />
                    <SolidColorBrush x:Key="TextControlSelectionHighlightForeground" Color="{StaticResource TextOnAccentFillColorSelectedText}" />
                    <SolidColorBrush x:Key="TextControlSelectionHighlightColor" Color="#FF523A7C" />
                    <SolidColorBrush x:Key="TextSelectionHighlightColorThemeBrush" Color="#FF523A7C" />
                    <SolidColorBrush x:Key="AccentFillColorSelectedTextBackgroundBrush" Color="#FF523A7C" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
            <Style TargetType="Control">
                <Setter Property="UseSystemFocusVisuals" Value="False" />
            </Style>
        </ResourceDictionary>
    </maui:MauiWinUIApplication.Resources>
</maui:MauiWinUIApplication>
