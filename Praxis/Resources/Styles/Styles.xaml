<?xml version="1.0" encoding="UTF-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">
    <Style TargetType="Page" ApplyToDerivedTypes="True">
        <Setter Property="BackgroundColor" Value="Transparent" />
    </Style>

    <Style TargetType="Label">
        <Setter Property="FontFamily" Value="{OnPlatform WinUI='Yu Gothic UI'}" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource TextLight}, Dark={StaticResource TextDark}}" />
        <Setter Property="FontSize" Value="14" />
    </Style>

    <Style TargetType="Entry" ApplyToDerivedTypes="True">
        <Setter Property="FontFamily" Value="{OnPlatform WinUI='Yu Gothic UI'}" />
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#54FFFFFF, Dark=#68282D34}" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource TextLight}, Dark={StaticResource TextDark}}" />
        <Setter Property="PlaceholderColor" Value="{AppThemeBinding Light=#8A8A8A, Dark=#909090}" />
        <Setter Property="HeightRequest" Value="40" />
    </Style>

    <Style TargetType="Editor">
        <Setter Property="FontFamily" Value="{OnPlatform WinUI='Yu Gothic UI'}" />
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#54FFFFFF, Dark=#68282D34}" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource TextLight}, Dark={StaticResource TextDark}}" />
    </Style>

    <Style TargetType="Button">
        <Setter Property="FontFamily" Value="{OnPlatform WinUI='Yu Gothic UI'}" />
        <Setter Property="TextColor" Value="{AppThemeBinding Light=#141414, Dark=#F0F0F0}" />
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#48FFFFFF, Dark=#5C333A42}" />
        <Setter Property="CornerRadius" Value="10" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="HeightRequest" Value="40" />
    </Style>
</ResourceDictionary>
