<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:behaviors="clr-namespace:Praxis.Behaviors"
             xmlns:controls="clr-namespace:Praxis.Controls"
             xmlns:converters="clr-namespace:Praxis.Converters"
             xmlns:shapes="clr-namespace:Microsoft.Maui.Controls.Shapes;assembly=Microsoft.Maui.Controls"
             xmlns:corelogic="clr-namespace:Praxis.Core.Logic;assembly=Praxis.Core"
             x:Class="Praxis.MainPage"
             x:Name="RootPage"
             Title="Praxis"
             BackgroundColor="Transparent">
    <ContentPage.Resources>
        <converters:BoolToScrollBarVisibilityConverter x:Key="BoolToScrollBarVisibilityConverter" />
        <Color x:Key="DummyRootGlassLight">#24FFFFFF</Color>
        <Color x:Key="DummyRootGlassDark">#3021262D</Color>
        <Color x:Key="GlassPanelLight">#00FFFFFF</Color>
        <Color x:Key="GlassPanelDark">#00000000</Color>
        <Color x:Key="GlassSurfaceLight">#00FFFFFF</Color>
        <Color x:Key="GlassSurfaceDark">#00000000</Color>
        <Color x:Key="GlassPopupLight">#24FFFFFF</Color>
        <Color x:Key="GlassPopupDark">#381E2228</Color>
        <Color x:Key="GlassInputLight">#30FFFFFF</Color>
        <Color x:Key="GlassInputDark">#40363B43</Color>
        <Color x:Key="GlassButtonLight">#6AFFFFFF</Color>
        <Color x:Key="GlassButtonDark">#78363B43</Color>
        <Color x:Key="GlassButtonStrokeLight">#B6FFFFFF</Color>
        <Color x:Key="GlassButtonStrokeDark">#747C8794</Color>
        <Color x:Key="GlassStrokeLight">#9FFFFFFF</Color>
        <Color x:Key="GlassStrokeDark">#66717B88</Color>
        <Style x:Key="PlacementButtonTextLabelStyle"
               TargetType="Label">
            <Setter Property="FontSize" Value="{OnPlatform Default=12, MacCatalyst=14}" />
            <Setter Property="FontAutoScalingEnabled" Value="False" />
        </Style>
        <Style x:Key="GlassModalActionButtonStyle"
               TargetType="Button">
            <Setter Property="HeightRequest" Value="38" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="BorderWidth" Value="1" />
            <Setter Property="BorderColor" Value="{AppThemeBinding Light={StaticResource GlassButtonStrokeLight}, Dark={StaticResource GlassButtonStrokeDark}}" />
            <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource GlassButtonLight}, Dark={StaticResource GlassButtonDark}}" />
            <Setter Property="TextColor" Value="{AppThemeBinding Light=#050505, Dark=#FFFFFF}" />
        </Style>
        <Style x:Key="GlassCopyButtonStyle"
               TargetType="Button">
            <Setter Property="HeightRequest" Value="40" />
            <Setter Property="WidthRequest" Value="40" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="BorderWidth" Value="1" />
            <Setter Property="BorderColor" Value="{AppThemeBinding Light={StaticResource GlassButtonStrokeLight}, Dark={StaticResource GlassButtonStrokeDark}}" />
            <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource GlassButtonLight}, Dark={StaticResource GlassButtonDark}}" />
            <Setter Property="TextColor" Value="{AppThemeBinding Light=#050505, Dark=#FFFFFF}" />
        </Style>
    </ContentPage.Resources>

    <Grid x:Name="RootGrid" Padding="18" RowDefinitions="Auto,*,Auto,Auto" RowSpacing="14" BackgroundColor="Transparent">
        <Grid.GestureRecognizers>
            <PointerGestureRecognizer PointerPressed="RootGrid_PointerPressed"
                                      PointerMoved="RootGrid_PointerMoved"
                                      PointerExited="RootGrid_PointerExited" />
        </Grid.GestureRecognizers>
        <controls:MaterialFrame x:Name="DummyRootGlassFrame"
                                Grid.RowSpan="4"
                                CornerRadius="28"
                                MacOSBehindWindowBlur="True"
                                MacOSBackdropOpacity="0.30"
                                InputTransparent="True"
                                HorizontalOptions="Fill"
                                VerticalOptions="Fill"
                                Stroke="{AppThemeBinding Light={StaticResource GlassStrokeLight}, Dark={StaticResource GlassStrokeDark}}"
                                StrokeThickness="1"
                                BackgroundColor="{AppThemeBinding Light={StaticResource DummyRootGlassLight}, Dark={StaticResource DummyRootGlassDark}}">
            <controls:MaterialFrame.Shadow>
                <Shadow Brush="{AppThemeBinding Light=#44000000, Dark=#B0000000}" Opacity="0.22" Offset="0,18" Radius="34" />
            </controls:MaterialFrame.Shadow>
        </controls:MaterialFrame>
        <Grid x:Name="TopBarGrid" ColumnDefinitions="2*,Auto,2*" ColumnSpacing="8">
            <Grid Grid.Column="0">
                <controls:CommandEntry x:Name="MainCommandEntry"
                                       Placeholder="Command"
                                       Text="{Binding CommandInput}"
                                       BackgroundColor="{AppThemeBinding Light={StaticResource GlassInputLight}, Dark={StaticResource GlassInputDark}}"
                                       ReturnType="Go"
                                       ReturnCommand="{Binding ExecuteCommandInputCommand}"
                                       Focused="MainCommandEntry_Focused"
                                       HandlerChanged="MainCommandEntry_HandlerChanged">
                    <controls:CommandEntry.GestureRecognizers>
                        <TapGestureRecognizer Tapped="MainCommandEntry_Tapped" />
                        <PointerGestureRecognizer PointerPressed="MainCommandEntry_PointerPressed" />
                    </controls:CommandEntry.GestureRecognizers>
                </controls:CommandEntry>
                <Border HorizontalOptions="End"
                        VerticalOptions="Center"
                        Margin="0,0,6,0"
                        TranslationX="-8"
                        WidthRequest="18"
                        HeightRequest="18"
                        Padding="0"
                        StrokeThickness="0"
                        BackgroundColor="{AppThemeBinding Light=#8A8A8A, Dark=#6E6E6E}"
                        Opacity="0"
                        InputTransparent="True"
                        StrokeShape="RoundRectangle 9"
                        ZIndex="2">
                    <Border.Triggers>
                        <DataTrigger TargetType="Border"
                                     Binding="{Binding IsCommandInputClearVisible}"
                                     Value="True">
                            <Setter Property="Opacity" Value="1" />
                            <Setter Property="InputTransparent" Value="False" />
                        </DataTrigger>
                    </Border.Triggers>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="CommandClearButton_Tapped" />
                        <PointerGestureRecognizer PointerEntered="ClearButton_PointerEntered"
                                                  PointerExited="ClearButton_PointerExited" />
                    </Border.GestureRecognizers>
                    <Grid x:Name="CommandClearGlyph"
                          WidthRequest="9" HeightRequest="9"
                          HorizontalOptions="Center"
                          VerticalOptions="Center"
                          InputTransparent="True">
                        <BoxView WidthRequest="9"
                                 HeightRequest="1.6"
                                 Color="{AppThemeBinding Light=#F8F8F8, Dark=#F2F2F2}"
                                 Rotation="45"
                                 HorizontalOptions="Center"
                                 VerticalOptions="Center" />
                        <BoxView WidthRequest="9"
                                 HeightRequest="1.6"
                                 Color="{AppThemeBinding Light=#F8F8F8, Dark=#F2F2F2}"
                                 Rotation="-45"
                                 HorizontalOptions="Center"
                                 VerticalOptions="Center" />
                    </Grid>
                </Border>
            </Grid>
            <Border x:Name="CreateButton" Grid.Column="1"
                    WidthRequest="44"
                    HeightRequest="40"
                    StrokeThickness="0"
                    BackgroundColor="{AppThemeBinding Light=#48FFFFFF, Dark=#5C333A42}"
                    StrokeShape="RoundRectangle 10"
                    Padding="0">
                <Border.Behaviors>
                    <behaviors:HoverHandCursorBehavior />
                </Border.Behaviors>
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding CreateNewCommand}" />
                </Border.GestureRecognizers>
                <Grid WidthRequest="24"
                      HeightRequest="24"
                      HorizontalOptions="Center"
                      VerticalOptions="Center"
                      InputTransparent="True">
                    <shapes:Polygon Points="12,0.316 22.116,6.158 22.116,17.842 12,23.684 1.884,17.842 1.884,6.158"
                                    Fill="Transparent"
                                    Stroke="{AppThemeBinding Light=#5A5A5A, Dark=#C7C7C7}"
                                    StrokeThickness="0.5" />
                    <shapes:Ellipse WidthRequest="20"
                                    HeightRequest="20"
                                    HorizontalOptions="Center"
                                    VerticalOptions="Center"
                                    Fill="Transparent"
                                    Stroke="{AppThemeBinding Light=#707070, Dark=#BBBBBB}"
                                    StrokeThickness="0.5" />
                    <shapes:Polygon Points="22,12 17,3.342 7,3.342 2,12 7,20.658 17,20.658"
                                    Fill="Transparent"
                                    Stroke="{AppThemeBinding Light=#7F7F7F, Dark=#B0B0B0}"
                                    StrokeThickness="0.5" />

                    <BoxView WidthRequest="1.8"
                             HeightRequest="7.6"
                             HorizontalOptions="Center"
                             VerticalOptions="Center"
                             Color="{AppThemeBinding Light=#585858, Dark=#D2D2D2}" />
                    <BoxView WidthRequest="7.6"
                             HeightRequest="1.8"
                             HorizontalOptions="Center"
                             VerticalOptions="Center"
                             Color="{AppThemeBinding Light=#585858, Dark=#D2D2D2}" />
                </Grid>
            </Border>
            <Grid Grid.Column="2">
                <controls:SearchEntry x:Name="MainSearchEntry"
                                      Placeholder="Search"
                                      Text="{Binding SearchText}"
                                      BackgroundColor="{AppThemeBinding Light={StaticResource GlassInputLight}, Dark={StaticResource GlassInputDark}}"
                                      Focused="MainSearchEntry_Focused"
                                      HandlerChanged="MainSearchEntry_HandlerChanged">
                    <controls:SearchEntry.GestureRecognizers>
                        <TapGestureRecognizer Tapped="MainSearchEntry_Tapped" />
                        <PointerGestureRecognizer PointerPressed="MainSearchEntry_PointerPressed" />
                    </controls:SearchEntry.GestureRecognizers>
                </controls:SearchEntry>
                <Border HorizontalOptions="End"
                        VerticalOptions="Center"
                        Margin="0,0,6,0"
                        TranslationX="-8"
                        WidthRequest="18"
                        HeightRequest="18"
                        Padding="0"
                        StrokeThickness="0"
                        BackgroundColor="{AppThemeBinding Light=#8A8A8A, Dark=#6E6E6E}"
                        Opacity="0"
                        InputTransparent="True"
                        StrokeShape="RoundRectangle 9"
                        ZIndex="2">
                    <Border.Triggers>
                        <DataTrigger TargetType="Border"
                                     Binding="{Binding IsSearchTextClearVisible}"
                                     Value="True">
                            <Setter Property="Opacity" Value="1" />
                            <Setter Property="InputTransparent" Value="False" />
                        </DataTrigger>
                    </Border.Triggers>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="SearchClearButton_Tapped" />
                        <PointerGestureRecognizer PointerEntered="ClearButton_PointerEntered"
                                                  PointerExited="ClearButton_PointerExited" />
                    </Border.GestureRecognizers>
                    <Grid x:Name="SearchClearGlyph"
                          WidthRequest="9" HeightRequest="9"
                          HorizontalOptions="Center"
                          VerticalOptions="Center"
                          InputTransparent="True">
                        <BoxView WidthRequest="9"
                                 HeightRequest="1.6"
                                 Color="{AppThemeBinding Light=#F8F8F8, Dark=#F2F2F2}"
                                 Rotation="45"
                                 HorizontalOptions="Center"
                                 VerticalOptions="Center" />
                        <BoxView WidthRequest="9"
                                 HeightRequest="1.6"
                                 Color="{AppThemeBinding Light=#F8F8F8, Dark=#F2F2F2}"
                                 Rotation="-45"
                                 HorizontalOptions="Center"
                                 VerticalOptions="Center" />
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <controls:MaterialFrame x:Name="CommandSuggestionPopup"
                                Grid.RowSpan="4"
                                IsVisible="{Binding IsCommandSuggestionOpen}"
                                CornerRadius="10"
                                MacOSBehindWindowBlur="True"
                                MacOSBackdropOpacity="0.55"
                                Stroke="{AppThemeBinding Light={StaticResource GlassStrokeLight}, Dark={StaticResource GlassStrokeDark}}"
                                BackgroundColor="{AppThemeBinding Light={StaticResource GlassPopupLight}, Dark={StaticResource GlassPopupDark}}"
                                Padding="6"
                                HeightRequest="{Binding CommandSuggestionPopupHeight}"
                                MinimumHeightRequest="44"
                                MaximumHeightRequest="280"
                                HorizontalOptions="Start"
                                VerticalOptions="Start"
                                TranslationX="0"
                                TranslationY="0"
                                ZIndex="950">
            <controls:MaterialFrame.Shadow>
                <Shadow Brush="{AppThemeBinding Light=#55000000, Dark=#AA000000}" Opacity="0.22" Offset="0,8" Radius="18" />
            </controls:MaterialFrame.Shadow>
            <CollectionView IsVisible="False"
                            ItemsSource="{Binding CommandSuggestions}"
                            SelectionMode="None">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Vertical" ItemSpacing="2" />
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Grid ColumnDefinitions="1*,1*,4*" Padding="8,6" BackgroundColor="Transparent">
                            <Grid.Triggers>
                                <DataTrigger TargetType="Grid" Binding="{Binding IsSelected}" Value="True">
                                    <Setter Property="BackgroundColor"
                                            Value="{AppThemeBinding Light=#70F2F5F8, Dark=#70434851}" />
                                </DataTrigger>
                            </Grid.Triggers>
                            <Grid.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding Source={x:Reference RootPage}, Path=BindingContext.PickSuggestionCommand}"
                                                      CommandParameter="{Binding .}" />
                            </Grid.GestureRecognizers>
                            <Label Grid.Column="0"
                                   Text="{Binding Command}"
                                   LineBreakMode="TailTruncation" />
                            <Label Grid.Column="1"
                                   Text="{Binding ButtonText}"
                                   LineBreakMode="TailTruncation" />
                            <Label Grid.Column="2"
                                   Text="{Binding ToolArguments}"
                                   LineBreakMode="TailTruncation" />
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <ScrollView x:Name="CommandSuggestionScrollView"
                        IsVisible="True"
                        Orientation="Vertical">
                <VerticalStackLayout x:Name="CommandSuggestionStack"
                                     Spacing="2"
                                     HorizontalOptions="Fill" />
            </ScrollView>
        </controls:MaterialFrame>

        <controls:MaterialFrame Grid.Row="1"
                                CornerRadius="20"
                                MacOSBehindWindowBlur="False"
                                Stroke="Transparent"
                                StrokeThickness="0"
                                BackgroundColor="{AppThemeBinding Light={StaticResource GlassPanelLight}, Dark={StaticResource GlassPanelDark}}"
                                Padding="14"
                                SizeChanged="PlacementArea_SizeChanged">
            <Grid>
                <ScrollView Orientation="{Binding PlacementScrollOrientation}"
                            x:Name="PlacementScroll"
                            Scrolled="PlacementScroll_Scrolled"
                            HorizontalScrollBarVisibility="{Binding HasHorizontalOverflow, Converter={StaticResource BoolToScrollBarVisibilityConverter}}"
                            VerticalScrollBarVisibility="{Binding HasVerticalOverflow, Converter={StaticResource BoolToScrollBarVisibilityConverter}}">
                    <AbsoluteLayout x:Name="PlacementCanvas"
                                    WidthRequest="{Binding CanvasWidth}"
                                    HeightRequest="{Binding CanvasHeight}"
                                    BindableLayout.ItemsSource="{Binding VisibleButtons}">
                        <AbsoluteLayout.GestureRecognizers>
                            <PanGestureRecognizer PanUpdated="Selection_PanUpdated" />
                            <PointerGestureRecognizer PointerPressed="Selection_PointerPressed"
                                                      PointerMoved="Selection_PointerMoved"
                                                      PointerReleased="Selection_PointerReleased" />
                            <TapGestureRecognizer Buttons="Secondary"
                                                  Tapped="PlacementCanvas_SecondaryTapped" />
                        </AbsoluteLayout.GestureRecognizers>
                        <BindableLayout.ItemTemplate>
                            <DataTemplate>
                                <Border AbsoluteLayout.LayoutBounds="{Binding LayoutBounds}"
                                        AbsoluteLayout.LayoutFlags="None"
                                        Stroke="{AppThemeBinding Light=#9FFFFFFF, Dark=#5E74808C}"
                                        StrokeShape="RoundRectangle 12"
                                        BackgroundColor="{AppThemeBinding Light=#62FFFFFF, Dark=#78363B43}"
                                        Padding="0">
                                    <Border.Behaviors>
                                        <behaviors:GrabHandCursorBehavior />
                                        <behaviors:MiddleClickBehavior Command="{Binding Source={x:Reference RootPage}, Path=BindingContext.OpenEditorCommand}" />
                                    </Border.Behaviors>
                                    <Border.Triggers>
                                        <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="True">
                                            <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#86FFFFFF, Dark=#90505660}" />
                                        </DataTrigger>
                                        <DataTrigger TargetType="Border" Binding="{Binding UseInvertedThemeColors}" Value="True">
                                            <Setter Property="Stroke" Value="{AppThemeBinding Light=#75545454, Dark=#C9FFFFFF}" />
                                            <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#BA363636, Dark=#E8FFFFFF}" />
                                        </DataTrigger>
                                        <MultiTrigger TargetType="Border">
                                            <MultiTrigger.Conditions>
                                                <BindingCondition Binding="{Binding IsSelected}" Value="True" />
                                                <BindingCondition Binding="{Binding UseInvertedThemeColors}" Value="True" />
                                            </MultiTrigger.Conditions>
                                            <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#C9505050, Dark=#E8DCDCDC}" />
                                        </MultiTrigger>
                                    </Border.Triggers>
                                    <Border.GestureRecognizers>
                                        <PanGestureRecognizer PanUpdated="Draggable_PanUpdated" />
                                        <PointerGestureRecognizer PointerPressed="Draggable_PointerPressed"
                                                                  PointerEntered="ButtonQuickLook_PointerEntered"
                                                                  PointerExited="ButtonQuickLook_PointerExited"
                                                                  PointerMoved="Draggable_PointerMoved"
                                                                  PointerReleased="Draggable_PointerReleased" />
                                        <TapGestureRecognizer Tapped="Draggable_Tapped" />
                                        <TapGestureRecognizer Buttons="Secondary"
                                                              Tapped="Draggable_SecondaryTapped" />
                                    </Border.GestureRecognizers>
                                    <Grid Padding="0,0" InputTransparent="True">
                                        <Label Text="{Binding ButtonText}"
                                               Style="{StaticResource PlacementButtonTextLabelStyle}"
                                               TextColor="{AppThemeBinding Light=#050505, Dark=#FFFFFF}"
                                               HorizontalTextAlignment="Center"
                                               VerticalTextAlignment="Center">
                                            <Label.Triggers>
                                                <DataTrigger TargetType="Label" Binding="{Binding UseInvertedThemeColors}" Value="True">
                                                    <Setter Property="TextColor" Value="{AppThemeBinding Light=#FFFFFF, Dark=#050505}" />
                                                </DataTrigger>
                                            </Label.Triggers>
                                        </Label>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </AbsoluteLayout>
                </ScrollView>
                <Border x:Name="SelectionRect"
                        IsVisible="False"
                        InputTransparent="True"
                        ZIndex="1000"
                        HorizontalOptions="Start"
                        VerticalOptions="Start"
                        WidthRequest="0"
                        HeightRequest="0"
                        Stroke="{AppThemeBinding Light=#7A7A7A, Dark=#A8A8A8}"
                        StrokeThickness="2"
                        BackgroundColor="{AppThemeBinding Light=#40B0B0B0, Dark=#40686868}"
                        StrokeShape="RoundRectangle 2" />
            </Grid>
        </controls:MaterialFrame>

        <controls:MaterialFrame x:Name="DockRegionBorder"
                                Grid.Row="2"
                                CornerRadius="20"
                                MacOSBehindWindowBlur="False"
                                Stroke="Transparent"
                                StrokeThickness="0"
                                BackgroundColor="{AppThemeBinding Light={StaticResource GlassPanelLight}, Dark={StaticResource GlassPanelDark}}"
                                Margin="{OnPlatform Default='0', WinUI='0,-4,0,-4', MacCatalyst='0,-4,0,-4'}"
                                Padding="12"
                                MinimumHeightRequest="{OnPlatform Default=92, WinUI=100, MacCatalyst=100}">
            <controls:MaterialFrame.GestureRecognizers>
                <PointerGestureRecognizer PointerEntered="DockRegion_PointerEntered"
                                          PointerExited="DockRegion_PointerExited" />
            </controls:MaterialFrame.GestureRecognizers>
            <Grid>
                <ScrollView x:Name="DockScroll"
                            Orientation="Horizontal"
                            HandlerChanged="DockScroll_HandlerChanged"
                            HorizontalScrollBarVisibility="Never">
                    <ScrollView.GestureRecognizers>
                        <PointerGestureRecognizer PointerEntered="DockRegion_PointerEntered"
                                                  PointerExited="DockRegion_PointerExited" />
                    </ScrollView.GestureRecognizers>
                    <HorizontalStackLayout x:Name="DockButtonsStack" Spacing="10" BindableLayout.ItemsSource="{Binding DockButtons}">
                        <HorizontalStackLayout.GestureRecognizers>
                            <PointerGestureRecognizer PointerEntered="DockRegion_PointerEntered"
                                                      PointerExited="DockRegion_PointerExited" />
                        </HorizontalStackLayout.GestureRecognizers>
                        <BindableLayout.ItemTemplate>
                            <DataTemplate>
                                <Border Stroke="{AppThemeBinding Light=#9FFFFFFF, Dark=#5E74808C}"
                                        StrokeShape="RoundRectangle 12"
                                        BackgroundColor="{AppThemeBinding Light=#62FFFFFF, Dark=#78363B43}"
                                        WidthRequest="{x:Static corelogic:ButtonLayoutDefaults.Width}"
                                        HeightRequest="{x:Static corelogic:ButtonLayoutDefaults.Height}"
                                        Padding="0">
                                    <Border.Triggers>
                                        <DataTrigger TargetType="Border" Binding="{Binding UseInvertedThemeColors}" Value="True">
                                            <Setter Property="Stroke" Value="{AppThemeBinding Light=#75545454, Dark=#C9FFFFFF}" />
                                            <Setter Property="BackgroundColor" Value="{AppThemeBinding Light=#BA363636, Dark=#E8FFFFFF}" />
                                        </DataTrigger>
                                    </Border.Triggers>
                                    <Border.Behaviors>
                                        <behaviors:HoverHandCursorBehavior />
                                        <behaviors:MiddleClickBehavior Command="{Binding Source={x:Reference RootPage}, Path=BindingContext.OpenEditorCommand}" />
                                    </Border.Behaviors>
                                    <Grid Padding="10,6">
                                        <Grid.GestureRecognizers>
                                            <PointerGestureRecognizer PointerPressed="DockButton_PointerPressed"
                                                                      PointerEntered="ButtonQuickLook_PointerEntered"
                                                                      PointerExited="ButtonQuickLook_PointerExited" />
                                            <TapGestureRecognizer Command="{Binding Source={x:Reference RootPage}, Path=BindingContext.ExecuteButtonCommand}"
                                                                  CommandParameter="{Binding .}" />
                                            <TapGestureRecognizer Buttons="Secondary"
                                                                  Tapped="DockButton_SecondaryTapped" />
                                        </Grid.GestureRecognizers>
                                        <Label Text="{Binding ButtonText}"
                                               Style="{StaticResource PlacementButtonTextLabelStyle}"
                                               TextColor="{AppThemeBinding Light=#050505, Dark=#FFFFFF}"
                                               HorizontalTextAlignment="Center"
                                               VerticalTextAlignment="Center">
                                            <Label.Triggers>
                                                <DataTrigger TargetType="Label" Binding="{Binding UseInvertedThemeColors}" Value="True">
                                                    <Setter Property="TextColor" Value="{AppThemeBinding Light=#FFFFFF, Dark=#050505}" />
                                                </DataTrigger>
                                            </Label.Triggers>
                                        </Label>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </HorizontalStackLayout>
                </ScrollView>

                <Border x:Name="DockScrollBarMask"
                        HeightRequest="12"
                        VerticalOptions="End"
                        Margin="0,0,0,2"
                        InputTransparent="True"
                        BackgroundColor="{AppThemeBinding Light={StaticResource GlassPanelLight}, Dark={StaticResource GlassPanelDark}}"
                        StrokeThickness="0"
                        IsVisible="True" />
            </Grid>
        </controls:MaterialFrame>

        <controls:MaterialFrame x:Name="StatusBarBorder"
                                Grid.Row="3"
                                CornerRadius="10"
                                MacOSBehindWindowBlur="False"
                                Stroke="Transparent"
                                StrokeThickness="0"
                                BackgroundColor="{AppThemeBinding Light={StaticResource GlassSurfaceLight}, Dark={StaticResource GlassSurfaceDark}}"
                                Padding="10,6">
            <Label Text="{Binding StatusText}" FontSize="13" />
        </controls:MaterialFrame>

        <controls:MaterialFrame x:Name="QuickLookPopup"
                                Grid.RowSpan="4"
                                IsVisible="False"
                                CornerRadius="12"
                                MacOSBehindWindowBlur="True"
                                MacOSBackdropOpacity="0.62"
                                Stroke="{AppThemeBinding Light={StaticResource GlassStrokeLight}, Dark={StaticResource GlassStrokeDark}}"
                                BackgroundColor="{AppThemeBinding Light={StaticResource GlassPopupLight}, Dark={StaticResource GlassPopupDark}}"
                                Padding="10,9"
                                WidthRequest="420"
                                MaximumWidthRequest="460"
                                HorizontalOptions="Start"
                                VerticalOptions="Start"
                                TranslationX="0"
                                TranslationY="0"
                                ZIndex="960">
            <controls:MaterialFrame.Shadow>
                <Shadow Brush="{AppThemeBinding Light=#44000000, Dark=#88000000}" Opacity="0.18" Offset="0,6" Radius="16" />
            </controls:MaterialFrame.Shadow>
            <VerticalStackLayout Spacing="3">
                <Label x:Name="QuickLookCommandLabel"
                       FontSize="12"
                       MaxLines="2"
                       LineBreakMode="TailTruncation"
                       TextColor="{AppThemeBinding Light=#242424, Dark=#E4E4E4}" />
                <Label x:Name="QuickLookToolLabel"
                       FontSize="12"
                       MaxLines="2"
                       LineBreakMode="TailTruncation"
                       TextColor="{AppThemeBinding Light=#3A3A3A, Dark=#D4D4D4}" />
                <Label x:Name="QuickLookArgumentsLabel"
                       FontSize="12"
                       MaxLines="2"
                       LineBreakMode="TailTruncation"
                       TextColor="{AppThemeBinding Light=#3A3A3A, Dark=#D4D4D4}" />
                <Label x:Name="QuickLookClipWordLabel"
                       FontSize="12"
                       MaxLines="2"
                       LineBreakMode="TailTruncation"
                       TextColor="{AppThemeBinding Light=#3A3A3A, Dark=#D4D4D4}" />
                <Label x:Name="QuickLookNoteLabel"
                       FontSize="12"
                       MaxLines="2"
                       LineBreakMode="TailTruncation"
                       TextColor="{AppThemeBinding Light=#3A3A3A, Dark=#D4D4D4}" />
            </VerticalStackLayout>
        </controls:MaterialFrame>

        <Grid Grid.RowSpan="4"
              IsVisible="{Binding IsContextMenuOpen}"
              BackgroundColor="Transparent">
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Command="{Binding CloseContextMenuCommand}" />
            </Grid.GestureRecognizers>
            <controls:MaterialFrame HorizontalOptions="Center"
                                    VerticalOptions="Center"
                                    WidthRequest="220"
                                    Padding="10"
                                    CornerRadius="14"
                                    MacOSBehindWindowBlur="True"
                                    MacOSBackdropOpacity="0.55"
                                    Stroke="{AppThemeBinding Light={StaticResource GlassStrokeLight}, Dark={StaticResource GlassStrokeDark}}"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource GlassPopupLight}, Dark={StaticResource GlassPopupDark}}">
                <VerticalStackLayout Spacing="8">
                    <Button x:Name="ContextEditButton"
                            Text="Edit"
                            HandlerChanged="ContextActionButton_HandlerChanged"
                            Focused="ContextActionButton_Focused"
                            Unfocused="ContextActionButton_Unfocused"
                            Command="{Binding ContextEditCommand}">
                        <Button.Behaviors>
                            <behaviors:HoverHandCursorBehavior />
                        </Button.Behaviors>
                    </Button>
                    <Button x:Name="ContextDeleteButton"
                            Text="Delete"
                            HandlerChanged="ContextActionButton_HandlerChanged"
                            Focused="ContextActionButton_Focused"
                            Unfocused="ContextActionButton_Unfocused"
                            Command="{Binding ContextDeleteCommand}">
                        <Button.Behaviors>
                            <behaviors:HoverHandCursorBehavior />
                        </Button.Behaviors>
                    </Button>
                </VerticalStackLayout>
            </controls:MaterialFrame>
        </Grid>

        <Grid x:Name="EditorOverlay"
              Grid.RowSpan="4"
              IsVisible="{Binding IsEditorOpen}"
              BackgroundColor="Transparent">
            <controls:MaterialFrame HorizontalOptions="Center"
                                    VerticalOptions="Center"
                                    WidthRequest="760"
                                    MaximumWidthRequest="860"
                                    Padding="18"
                                    CornerRadius="18"
                                    MacOSBehindWindowBlur="True"
                                    MacOSBackdropOpacity="0.62"
                                    Stroke="{AppThemeBinding Light={StaticResource GlassStrokeLight}, Dark={StaticResource GlassStrokeDark}}"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource GlassPopupLight}, Dark={StaticResource GlassPopupDark}}">
                <controls:MaterialFrame.Shadow>
                    <Shadow Brush="{AppThemeBinding Light=#50000000, Dark=#7A000000}" Opacity="0.16" Offset="0,10" Radius="22" />
                </controls:MaterialFrame.Shadow>

                <Grid RowDefinitions="Auto,Auto" RowSpacing="12">
                    <ScrollView x:Name="EditorFieldsScrollView"
                                Grid.Row="0"
                                VerticalOptions="Start">
                        <Grid ColumnDefinitions="140,*,44" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" ColumnSpacing="8" RowSpacing="8">
                            <Label Grid.Row="0" Grid.Column="0" Text="GUID" VerticalTextAlignment="Center" HeightRequest="40" />
                            <Entry x:Name="ModalGuidEntry" Grid.Row="0" Grid.Column="1" Text="{Binding Editor.GuidText}" IsReadOnly="{OnPlatform Default=True, MacCatalyst=False}" HeightRequest="40" BackgroundColor="{AppThemeBinding Light={StaticResource GlassInputLight}, Dark={StaticResource GlassInputDark}}" HandlerChanged="ModalGuidEntry_HandlerChanged" />
                            <Button x:Name="CopyGuidButton" Grid.Row="0" Grid.Column="2" Style="{StaticResource GlassCopyButtonStyle}" Text="{OnPlatform WinUI='&#xE8C8;', MacCatalyst='⧉'}" FontFamily="{OnPlatform WinUI='Segoe MDL2 Assets', MacCatalyst=''}"
                                    Command="{Binding CopyFieldCommand}"
                                    CommandParameter="{Binding Editor.GuidText}" HeightRequest="40" WidthRequest="40" Padding="0"
                                    VerticalOptions="Center"
                                    HandlerChanged="ModalGlassButton_HandlerChanged"
                                    Clicked="CopyIconButton_Clicked">
                                <Button.Behaviors>
                                    <behaviors:HoverHandCursorBehavior />
                                </Button.Behaviors>
                            </Button>

                            <Label Grid.Row="1" Grid.Column="0" Text="Button Text" VerticalTextAlignment="Center" HeightRequest="40" />
                            <Entry x:Name="ModalButtonTextEntry" Grid.Row="1" Grid.Column="1" Text="{Binding Editor.ButtonText}" HeightRequest="40" BackgroundColor="{AppThemeBinding Light={StaticResource GlassInputLight}, Dark={StaticResource GlassInputDark}}" HandlerChanged="ModalTextInput_HandlerChanged" />
                            <Button x:Name="CopyButtonTextButton" Grid.Row="1" Grid.Column="2" Style="{StaticResource GlassCopyButtonStyle}" Text="{OnPlatform WinUI='&#xE8C8;', MacCatalyst='⧉'}" FontFamily="{OnPlatform WinUI='Segoe MDL2 Assets', MacCatalyst=''}"
                                    Command="{Binding CopyFieldCommand}"
                                    CommandParameter="{Binding Editor.ButtonText}" HeightRequest="40" WidthRequest="40" Padding="0"
                                    VerticalOptions="Center"
                                    HandlerChanged="ModalGlassButton_HandlerChanged"
                                    Clicked="CopyIconButton_Clicked">
                                <Button.Behaviors>
                                    <behaviors:HoverHandCursorBehavior />
                                </Button.Behaviors>
                            </Button>

                            <Label Grid.Row="2" Grid.Column="0" Text="Command" VerticalTextAlignment="Center" HeightRequest="40" />
                            <controls:CommandEntry x:Name="ModalCommandEntry" Grid.Row="2" Grid.Column="1" Text="{Binding Editor.Command}" HeightRequest="40"
                                                   BackgroundColor="{AppThemeBinding Light={StaticResource GlassInputLight}, Dark={StaticResource GlassInputDark}}"
                                                   EnableCommandNavigationShortcuts="False"
                                                   EnableNativeActivationFocus="False"
                                                   EnforceAsciiInput="True"
                                                   KeepAsciiImeWhileFocused="True"
                                                   HandlerChanged="ModalTextInput_HandlerChanged" />
                            <Button x:Name="CopyCommandButton" Grid.Row="2" Grid.Column="2" Text="{OnPlatform WinUI='&#xE8C8;', MacCatalyst='⧉'}" FontFamily="{OnPlatform WinUI='Segoe MDL2 Assets', MacCatalyst=''}"
                                    Style="{StaticResource GlassCopyButtonStyle}"
                                    Command="{Binding CopyFieldCommand}"
                                    CommandParameter="{Binding Editor.Command}" HeightRequest="40" WidthRequest="40" Padding="0"
                                    VerticalOptions="Center"
                                    HandlerChanged="ModalGlassButton_HandlerChanged"
                                    Clicked="CopyIconButton_Clicked">
                                <Button.Behaviors>
                                    <behaviors:HoverHandCursorBehavior />
                                </Button.Behaviors>
                            </Button>

                            <Label Grid.Row="3" Grid.Column="0" Text="Tool" VerticalTextAlignment="Center" HeightRequest="40" />
                            <Entry x:Name="ModalToolEntry" Grid.Row="3" Grid.Column="1" Text="{Binding Editor.Tool}" HeightRequest="40" BackgroundColor="{AppThemeBinding Light={StaticResource GlassInputLight}, Dark={StaticResource GlassInputDark}}" HandlerChanged="ModalTextInput_HandlerChanged" />
                            <Button x:Name="CopyToolButton" Grid.Row="3" Grid.Column="2" Style="{StaticResource GlassCopyButtonStyle}" Text="{OnPlatform WinUI='&#xE8C8;', MacCatalyst='⧉'}" FontFamily="{OnPlatform WinUI='Segoe MDL2 Assets', MacCatalyst=''}"
                                    Command="{Binding CopyFieldCommand}"
                                    CommandParameter="{Binding Editor.Tool}" HeightRequest="40" WidthRequest="40" Padding="0"
                                    VerticalOptions="Center"
                                    HandlerChanged="ModalGlassButton_HandlerChanged"
                                    Clicked="CopyIconButton_Clicked">
                                <Button.Behaviors>
                                    <behaviors:HoverHandCursorBehavior />
                                </Button.Behaviors>
                            </Button>

                            <Label Grid.Row="4" Grid.Column="0" Text="Arguments" VerticalTextAlignment="Center" HeightRequest="40" />
                            <Entry x:Name="ModalArgumentsEntry" Grid.Row="4" Grid.Column="1" Text="{Binding Editor.Arguments}" HeightRequest="40" BackgroundColor="{AppThemeBinding Light={StaticResource GlassInputLight}, Dark={StaticResource GlassInputDark}}" HandlerChanged="ModalTextInput_HandlerChanged" />
                            <Button x:Name="CopyArgumentsButton" Grid.Row="4" Grid.Column="2" Style="{StaticResource GlassCopyButtonStyle}" Text="{OnPlatform WinUI='&#xE8C8;', MacCatalyst='⧉'}" FontFamily="{OnPlatform WinUI='Segoe MDL2 Assets', MacCatalyst=''}"
                                    Command="{Binding CopyFieldCommand}"
                                    CommandParameter="{Binding Editor.Arguments}" HeightRequest="40" WidthRequest="40" Padding="0"
                                    VerticalOptions="Center"
                                    HandlerChanged="ModalGlassButton_HandlerChanged"
                                    Clicked="CopyIconButton_Clicked">
                                <Button.Behaviors>
                                    <behaviors:HoverHandCursorBehavior />
                                </Button.Behaviors>
                            </Button>

                            <Label Grid.Row="5" Grid.Column="0" Text="Clip Word" VerticalTextAlignment="Center" HeightRequest="40" />
                            <Border x:Name="ModalClipWordContainer"
                                    Grid.Row="5"
                                    Grid.Column="1"
                                    Stroke="Transparent"
                                    StrokeThickness="0"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource GlassInputLight}, Dark={StaticResource GlassInputDark}}"
                                    StrokeShape="RoundRectangle 6"
                                    MinimumHeightRequest="40"
                                    HeightRequest="40"
                                    Padding="0">
                                <Grid>
                                    <controls:TabNavigatingEditor x:Name="ModalClipWordEditor"
                                                                  Text="{Binding Editor.ClipText}"
                                                                  AutoSize="Disabled"
                                                                  MinimumHeightRequest="40"
                                                                  HeightRequest="40"
                                                                  BackgroundColor="{AppThemeBinding Light={StaticResource GlassInputLight}, Dark={StaticResource GlassInputDark}}"
                                                                  TextColor="{AppThemeBinding Light=#111111, Dark=#F2F2F2}"
                                                                  TextChanged="ModalClipWordEditor_TextChanged"
                                                                  HandlerChanged="ModalClipWordEditor_HandlerChanged"
                                                                  Focused="ModalClipWordEditor_Focused"
                                                                  Unfocused="ModalClipWordEditor_Unfocused"
                                                                  Margin="0" />
                                    <BoxView x:Name="ModalClipWordFocusUnderline"
                                             IsVisible="False"
                                             HeightRequest="1.5"
                                             VerticalOptions="End"
                                             HorizontalOptions="Fill"
                                             Margin="5,0"
                                             InputTransparent="True"
                                             BackgroundColor="{AppThemeBinding Light=#4A4A4A, Dark=#A0A0A0}" />
                                </Grid>
                            </Border>
                            <Button x:Name="CopyClipWordButton" Grid.Row="5" Grid.Column="2" Style="{StaticResource GlassCopyButtonStyle}" Text="{OnPlatform WinUI='&#xE8C8;', MacCatalyst='⧉'}" FontFamily="{OnPlatform WinUI='Segoe MDL2 Assets', MacCatalyst=''}"
                                    Command="{Binding CopyFieldCommand}"
                                    CommandParameter="{Binding Editor.ClipText}" HeightRequest="40" WidthRequest="40" Padding="0" VerticalOptions="Center"
                                    HandlerChanged="ModalGlassButton_HandlerChanged"
                                    Clicked="CopyIconButton_Clicked">
                                <Button.Behaviors>
                                    <behaviors:HoverHandCursorBehavior />
                                </Button.Behaviors>
                            </Button>

                            <Label Grid.Row="6" Grid.Column="0" Text="Note" VerticalTextAlignment="Center" HeightRequest="40" />
                            <Border x:Name="ModalNoteContainer"
                                    Grid.Row="6"
                                    Grid.Column="1"
                                    Stroke="Transparent"
                                    StrokeThickness="0"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource GlassInputLight}, Dark={StaticResource GlassInputDark}}"
                                    StrokeShape="RoundRectangle 6"
                                    MinimumHeightRequest="40"
                                    HeightRequest="40"
                                    Padding="0">
                                <Grid>
                                    <controls:TabNavigatingEditor x:Name="ModalNoteEditor"
                                                                  Text="{Binding Editor.Note}"
                                                                  AutoSize="Disabled"
                                                                  MinimumHeightRequest="40"
                                                                  HeightRequest="40"
                                                                  BackgroundColor="{AppThemeBinding Light={StaticResource GlassInputLight}, Dark={StaticResource GlassInputDark}}"
                                                                  TextColor="{AppThemeBinding Light=#111111, Dark=#F2F2F2}"
                                                                  TextChanged="ModalNoteEditor_TextChanged"
                                                                  HandlerChanged="ModalNoteEditor_HandlerChanged"
                                                                  Focused="ModalNoteEditor_Focused"
                                                                  Unfocused="ModalNoteEditor_Unfocused"
                                                                  Margin="0" />
                                    <BoxView x:Name="ModalNoteFocusUnderline"
                                             IsVisible="False"
                                             HeightRequest="1.5"
                                             VerticalOptions="End"
                                             HorizontalOptions="Fill"
                                             Margin="5,0"
                                             InputTransparent="True"
                                             BackgroundColor="{AppThemeBinding Light=#4A4A4A, Dark=#A0A0A0}" />
                                </Grid>
                            </Border>
                            <Button x:Name="CopyNoteButton" Grid.Row="6" Grid.Column="2" Style="{StaticResource GlassCopyButtonStyle}" Text="{OnPlatform WinUI='&#xE8C8;', MacCatalyst='⧉'}" FontFamily="{OnPlatform WinUI='Segoe MDL2 Assets', MacCatalyst=''}"
                                    Command="{Binding CopyFieldCommand}"
                                    CommandParameter="{Binding Editor.Note}" HeightRequest="40" WidthRequest="40" Padding="0" VerticalOptions="Center"
                                    HandlerChanged="ModalGlassButton_HandlerChanged"
                                    Clicked="CopyIconButton_Clicked">
                                <Button.Behaviors>
                                    <behaviors:HoverHandCursorBehavior />
                                </Button.Behaviors>
                            </Button>

                            <Label Grid.Row="7" Grid.Column="0" Text="Invert Theme" VerticalTextAlignment="Center" HeightRequest="40" />
                            <HorizontalStackLayout Grid.Row="7" Grid.Column="1" Spacing="8" VerticalOptions="Center">
                                <Grid WidthRequest="18" HeightRequest="18" VerticalOptions="Center">
                                    <CheckBox x:Name="ModalInvertThemeCheckBox"
                                              IsChecked="{Binding Editor.UseInvertedThemeColors}"
                                              Focused="ModalEditorField_Focused"
                                              Color="{AppThemeBinding Light=#1A1A1A, Dark=#F2F2F2}"
                                              Opacity="0"
                                              WidthRequest="18"
                                              HeightRequest="18"
                                              VerticalOptions="Center"
                                              HorizontalOptions="Center" />
                                    <Grid WidthRequest="18"
                                          HeightRequest="18"
                                          VerticalOptions="Center"
                                          HorizontalOptions="Center">
                                        <Grid.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="ModalInvertThemeToggle_Tapped" />
                                        </Grid.GestureRecognizers>
                                        <BoxView Margin="1"
                                                 Color="{AppThemeBinding Light=#54FFFFFF, Dark=#68282D34}" />
                                        <BoxView IsVisible="{Binding Editor.UseInvertedThemeColors}"
                                                 Margin="1"
                                                 Color="{AppThemeBinding Light=#111111, Dark=#F2F2F2}" />
                                        <BoxView HeightRequest="1"
                                                 VerticalOptions="Start"
                                                 Color="{AppThemeBinding Light=#CECECE, Dark=#4E4E4E}" />
                                        <BoxView HeightRequest="1"
                                                 VerticalOptions="End"
                                                 Color="{AppThemeBinding Light=#CECECE, Dark=#4E4E4E}" />
                                        <BoxView WidthRequest="1"
                                                 HorizontalOptions="Start"
                                                 Color="{AppThemeBinding Light=#CECECE, Dark=#4E4E4E}" />
                                        <BoxView WidthRequest="1"
                                                 HorizontalOptions="End"
                                                 Color="{AppThemeBinding Light=#CECECE, Dark=#4E4E4E}" />
                                        <shapes:Polyline IsVisible="{Binding Editor.UseInvertedThemeColors}"
                                                         Points="1.4,5.6 3.5,8 8.9,2.1"
                                                         Stroke="{AppThemeBinding Light=#F2F2F2, Dark=#111111}"
                                                         StrokeThickness="2"
                                                         StrokeLineCap="Round"
                                                         StrokeLineJoin="Round"
                                                         HorizontalOptions="Center"
                                                         VerticalOptions="Center" />
                                    </Grid>
                                </Grid>
                                <Label Text="Use opposite theme colors for this button"
                                       VerticalTextAlignment="Center"
                                       LineBreakMode="TailTruncation">
                                    <Label.GestureRecognizers>
                                        <TapGestureRecognizer Tapped="ModalInvertThemeToggle_Tapped" />
                                    </Label.GestureRecognizers>
                                </Label>
                            </HorizontalStackLayout>
                        </Grid>
                    </ScrollView>

                    <HorizontalStackLayout Grid.Row="1"
                                           HorizontalOptions="Center"
                                           Spacing="10">
                        <Button x:Name="ModalCancelButton"
                                Style="{StaticResource GlassModalActionButtonStyle}"
                                Text="Cancel"
                                WidthRequest="96"
                                HandlerChanged="ModalGlassButton_HandlerChanged"
                                Unfocused="ModalActionButton_Unfocused"
                                Command="{Binding CancelEditorCommand}">
                            <Button.Behaviors>
                                <behaviors:HoverHandCursorBehavior />
                            </Button.Behaviors>
                        </Button>
                        <Button x:Name="ModalSaveButton"
                                Style="{StaticResource GlassModalActionButtonStyle}"
                                Text="Save"
                                WidthRequest="96"
                                HandlerChanged="ModalGlassButton_HandlerChanged"
                                Unfocused="ModalActionButton_Unfocused"
                                Command="{Binding SaveEditorCommand}">
                            <Button.Behaviors>
                                <behaviors:HoverHandCursorBehavior />
                            </Button.Behaviors>
                        </Button>
                    </HorizontalStackLayout>
                </Grid>
            </controls:MaterialFrame>
        </Grid>

        <Grid x:Name="ConflictOverlay"
              Grid.RowSpan="4"
              IsVisible="False"
              BackgroundColor="Transparent"
              ZIndex="980">
            <controls:MaterialFrame HorizontalOptions="Center"
                                    VerticalOptions="Center"
                                    WidthRequest="520"
                                    MaximumWidthRequest="620"
                                    Padding="18"
                                    CornerRadius="18"
                                    MacOSBehindWindowBlur="True"
                                    MacOSBackdropOpacity="0.62"
                                    Stroke="{AppThemeBinding Light={StaticResource GlassStrokeLight}, Dark={StaticResource GlassStrokeDark}}"
                                    BackgroundColor="{AppThemeBinding Light={StaticResource GlassPopupLight}, Dark={StaticResource GlassPopupDark}}">
                <controls:MaterialFrame.Shadow>
                    <Shadow Brush="{AppThemeBinding Light=#66000000, Dark=#AA000000}" Opacity="0.22" Offset="0,10" Radius="22" />
                </controls:MaterialFrame.Shadow>
                <VerticalStackLayout Spacing="12">
                    <Label x:Name="ConflictTitleLabel"
                           FontSize="22"
                           TextColor="{AppThemeBinding Light=#1A1A1A, Dark=#F2F2F2}" />
                    <Label x:Name="ConflictMessageLabel"
                           FontSize="14"
                           TextColor="{AppThemeBinding Light=#303030, Dark=#D0D0D0}" />
                    <HorizontalStackLayout HorizontalOptions="Center" Spacing="10">
                        <Button x:Name="ConflictReloadButton"
                                Text="Reload latest"
                                WidthRequest="132"
                                HandlerChanged="ConflictActionButton_HandlerChanged"
                                Focused="ConflictActionButton_Focused"
                                Unfocused="ConflictActionButton_Unfocused"
                                Clicked="ConflictReloadButton_Clicked">
                            <Button.Behaviors>
                                <behaviors:HoverHandCursorBehavior />
                            </Button.Behaviors>
                        </Button>
                        <Button x:Name="ConflictOverwriteButton"
                                Text="Overwrite mine"
                                WidthRequest="132"
                                HandlerChanged="ConflictActionButton_HandlerChanged"
                                Focused="ConflictActionButton_Focused"
                                Unfocused="ConflictActionButton_Unfocused"
                                Clicked="ConflictOverwriteButton_Clicked">
                            <Button.Behaviors>
                                <behaviors:HoverHandCursorBehavior />
                            </Button.Behaviors>
                        </Button>
                        <Button x:Name="ConflictCancelButton"
                                Text="Cancel"
                                WidthRequest="132"
                                HandlerChanged="ConflictActionButton_HandlerChanged"
                                Focused="ConflictActionButton_Focused"
                                Unfocused="ConflictActionButton_Unfocused"
                                Clicked="ConflictCancelButton_Clicked">
                            <Button.Behaviors>
                                <behaviors:HoverHandCursorBehavior />
                            </Button.Behaviors>
                        </Button>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </controls:MaterialFrame>
        </Grid>

        <Grid x:Name="CopyNoticeOverlay"
              Grid.RowSpan="4"
              IsVisible="False"
              Opacity="0"
              InputTransparent="True"
              ZIndex="999">
            <controls:MaterialFrame x:Name="CopyNoticeBox"
                                    HorizontalOptions="Center"
                                    VerticalOptions="Center"
                                    WidthRequest="78"
                                    HeightRequest="78"
                                    CornerRadius="18"
                                    MacOSBehindWindowBlur="True"
                                    MacOSBackdropOpacity="0.55"
                                    BackgroundColor="{AppThemeBinding Light=#D9FFFFFF, Dark=#D9202020}"
                                    Stroke="{AppThemeBinding Light={StaticResource GlassStrokeLight}, Dark={StaticResource GlassStrokeDark}}">
                <Label Text="{OnPlatform WinUI='&#xE8C8;', MacCatalyst='⧉'}"
                       FontFamily="{OnPlatform WinUI='Segoe MDL2 Assets', MacCatalyst=''}"
                       FontSize="30"
                       HorizontalTextAlignment="Center"
                       VerticalTextAlignment="Center"
                       TextColor="{AppThemeBinding Light=#202020, Dark=#F2F2F2}" />
            </controls:MaterialFrame>
        </Grid>
    </Grid>
</ContentPage>
